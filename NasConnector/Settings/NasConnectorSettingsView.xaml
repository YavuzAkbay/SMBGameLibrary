<UserControl x:Class="NasConnector.NasConnectorSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="600">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10" Width="560">

            <!-- NAS Path -->
            <TextBlock Text="NAS Games Folder (UNC path):" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Settings.NasBasePath, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"/>

            <!-- Local Install Path -->
            <TextBlock Text="Local Install Directory:" Margin="0,0,0,4"/>
            <DockPanel Margin="0,0,0,10">
                <Button DockPanel.Dock="Right" Content="Browse..." Width="80" Margin="5,0,0,0"
                        Click="BrowseLocalPath_Click"/>
                <TextBox Text="{Binding Settings.LocalInstallPath, UpdateSourceTrigger=PropertyChanged}"/>
            </DockPanel>

            <!-- SMB Authentication -->
            <Expander Header="Authentication (leave blank for current Windows user)" Margin="0,0,0,10">
                <StackPanel Margin="10,5,0,0">
                    <TextBlock Text="Username:" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Settings.SmbUsername, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8"/>
                    <TextBlock Text="Password:" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="PasswordBox" Margin="0,0,0,0"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>
                </StackPanel>
            </Expander>

            <!-- Test Connection -->
            <Button Content="Test Connection" HorizontalAlignment="Left" Padding="12,4"
                    Command="{Binding TestConnectionCommand}"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
